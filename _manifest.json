{
  "manifest_version": 2,
  "id": "small_sunshine.date-aware-plugin",
  "version": "2.0.0",
  "name": "日期感知插件",
  "description": "让麦麦能够更准确地感知日期和节假日信息，自动将\"昨天/今天/明天\"的日期注入到对话上下文中",
  "author": {
    "name": "small_sunshine",
    "url": "https://github.com/MCYXG233"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/MCYXG233/date_aware_plugin_New",
    "homepage": "https://github.com/MCYXG233/date_aware_plugin_New"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },
  "capabilities": ["send_message"],
  "i18n": {
    "default_locale": "zh-CN"
  },
  "keywords": [
    "日期",
    "节假日",
    "日历"
  ],
  "categories": [
    "Utilities"
  ]
}
